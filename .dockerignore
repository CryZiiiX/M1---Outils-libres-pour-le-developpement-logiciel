# ============================================================================
# .dockerignore - Fichiers à exclure du contexte Docker
# ============================================================================

# Résultats générés (régénérés lors de l'exécution)
back-end/results/
*.log

# Environnements virtuels Python
venv/
env/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Fichiers de configuration IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Fichiers Git
.git/
.gitignore
.gitattributes

# Fichiers temporaires
*.tmp
*.temp
.cache/
.pytest_cache/
.coverage
htmlcov/

# Node
front-end/node_modules/
front-end/dist/

# Fichiers système
.DS_Store
Thumbs.db
